DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
# Optional but recommended for faster command updates while developing
DISCORD_GUILD_ID=your_test_server_id_here

# Weekly auto roster scheduler (optional)
# AUTO_ROSTER_ENABLED=true
# Run /triggerweeklybatch once in each target channel to auto-register guild+channel
# Optional static target (must set both):
# AUTO_ROSTER_GUILD_ID=your_server_id_here
# AUTO_ROSTER_CHANNEL_ID=channel_id_for_weekly_roster_posts
# AUTO_ROSTER_TIMEZONE=Asia/Bangkok
# AUTO_ROSTER_DAY=tue # mon|tue|wed|thu|fri|sat|sun
# AUTO_ROSTER_HOUR=19
# AUTO_ROSTER_MINUTE=30
# AUTO_ROSTER_TITLE=Guild War # bot appends weekly Sat/Sun dates automatically
# AUTO_ROSTER_FORCE_EVENT=guildwar # optional testing override

# Optional: override dropdown/select choices (JSON array, max 25 items each)
# ROLE_OPTIONS_JSON=[{"label":"Tank","value":"tank","description":"Frontline"},{"label":"Healer","value":"healer","description":"Support"},{"label":"DPS","value":"dps","description":"Damage"}]
# WEAPON_OPTIONS_JSON=[{"label":"Stonesplit - Might","value":"Stonesplit - Might","description":"Tank weapon"}]
# TEAM_OPTIONS_JSON=[{"label":"Attack Team","value":"attack","description":"Offense"},{"label":"Defense Team","value":"defense","description":"Defense"}]
